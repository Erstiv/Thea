# Project Thea — Environment Variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to git — only .env.example

# VyprVPN (via Giganews) — for torrent traffic through gluetun
VYPRVPN_USER=your_vyprvpn_username
VYPRVPN_PASS=your_vyprvpn_password

# Notifiarr — get API key from https://notifiarr.com
NOTIFIARR_API_KEY=your_notifiarr_api_key

# Snap & Grab app uses its own .env at /opt/thea/snap-and-grab/.env
# See snap-and-grab/.env.example for those variables
